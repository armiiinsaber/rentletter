{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/shortlist/[token]",
      "regex": "^/shortlist/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPtoken": "nxtPtoken"
      },
      "namedRegex": "^/shortlist/(?<nxtPtoken>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/admin/stats",
      "regex": "^/admin/stats(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/stats(?:/)?$"
    },
    {
      "page": "/compliance",
      "regex": "^/compliance(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/compliance(?:/)?$"
    },
    {
      "page": "/demo",
      "regex": "^/demo(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/demo(?:/)?$"
    },
    {
      "page": "/faq",
      "regex": "^/faq(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/faq(?:/)?$"
    },
    {
      "page": "/landlord",
      "regex": "^/landlord(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/landlord(?:/)?$"
    },
    {
      "page": "/my-application",
      "regex": "^/my\\-application(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/my\\-application(?:/)?$"
    },
    {
      "page": "/privacy",
      "regex": "^/privacy(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/privacy(?:/)?$"
    },
    {
      "page": "/realtors",
      "regex": "^/realtors(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/realtors(?:/)?$"
    },
    {
      "page": "/terms",
      "regex": "^/terms(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/terms(?:/)?$"
    }
  ],
  "dataRoutes": [
    {
      "page": "/admin/stats",
      "dataRouteRegex": "^/_next/data/\\-C5mnHqpyyoEcjXFEWdJf/admin/stats\\.json$"
    },
    {
      "page": "/demo",
      "dataRouteRegex": "^/_next/data/\\-C5mnHqpyyoEcjXFEWdJf/demo\\.json$"
    },
    {
      "page": "/realtors",
      "dataRouteRegex": "^/_next/data/\\-C5mnHqpyyoEcjXFEWdJf/realtors\\.json$"
    }
  ],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}